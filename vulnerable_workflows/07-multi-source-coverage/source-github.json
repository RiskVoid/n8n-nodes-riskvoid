            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log GitHub Event": {
      "main": [
        [
          {
            "node": "Find User Activity",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Find User Activity": {
      "main": [
        [
          {
            "node": "Set Lookup Result",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Set Lookup Result": {
      "main": [
        [
          {
